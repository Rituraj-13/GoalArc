EMAIL_APP_PASSWORD=your-email-app-password
JWT_SECRET=your-secret-key
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/yourdb
VITE_AI_API_KEY=your-ai-api-key

# Create a .env file in the frontend directory with this variable
# Replace the value with your production backend URL when deploying
VITE_API_URL=http://localhost:3000

# Note: The frontend codebase currently hardcodes 'http://localhost:3000'
# in several places (like axios calls). To use this variable, you'll need
# to update those files to use `import.meta.env.VITE_API_URL` instead.